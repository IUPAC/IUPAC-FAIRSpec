{
  "$schema": "http://json-schema.org/draft/2020-12/schema#",
  "$id": "https://iupac.github.io/IUPAC-FAIRSpec/schema/fairspec.schema.0.1.2.json",

  "required": [
    "IUPAC.FAIRSpec.findingAid"
    ],
    "unevaluatedProperties": false,
    "properties": {
      "IUPAC.FAIRSpec.findingAid": {
        "description": "primary and only key in this object, marking the finding aid as an IUPAC FAIRSpec Finding Aid and serving as a 'magic number' at the start of the byte data",
        "type": "object",
        "required": [
          "id",
          "schema",
          "version",
          "created",
          "createdBy",
          "contents",
          "collectionSet"
          ],
          "unevaluatedProperties": false,
          "properties": {
            "ifdType": {
              "type": "string",
              "const": "org.iupac.fairdata.contrib.fairspec.FAIRSpecFindingAid"
            },
            "ifdTypeExtends": {
              "type": "string",
              "const": "org.iupac.fairdata.core.IFDFindingAid"
            },
            "schema": {
              "description": "the schema used to create this IUPAC FAIRSpec Finding Aid",
              "const": "https://iupac.github.io/IUPAC-FAIRSpec/schema/fairspec.schema.0.1.2.json"
            },
            "id": {
              "$ref": "#/$defs/def_field_id"
            },
            "version": {
              "description": "the version of this IFD Finding Aid,for example : IFD 0.0.5-alpha+2024.11.04;FAIRSpec 0.0.5-alpha+2024.11.04",
              "const": "IFD 0.1.2+2026.01.25;FAIRSpec 0.1.2+2026.01.25"
            },
            "created": {
              "description": "date and time of creation ISO 8601 date+time (UTC), for example: 2025-04-17T18:55Z",
              "type": "string"
            },
            "createdBy": {
              "description": "identifies the software used to create this finding aid. For example:  https://github.com/IUPAC/IUPAC-FAIRSpec/blob/main/src/main/java/com/integratedgraphics/extractor/DOICrawler.java DoiCrawler 0.0.7-beta+2025.02.17",
              "type": "string"
            },
            "contents": {
              "description": "contents of this finding aid",
              "type": "object",
              "unevaluatedProperties": false,
              "properties": {
                "collections": {
                  "type": "array",
                  "items": {
                    "anyOf": [
                      {
                        "type": "object",
                        "required": [
                          "id",
                          "count"
                          ],
                          "unevaluatedProperties": false,
                          "properties": {
                            "ifdType": {
                              "type": "string",
                              "const": "org.iupac.fairdata.sample.IFDSampleCollection"
                            },
                            "ifdTypeExtends": {
                              "type": "string",
                              "const": "org.iupac.fairdata.core.IFDCollection"
                            },
                            "id": {
                              "type": "string",
                              "const": "samples"
                            },
                            "count": {
                              "type": "integer"
                            }
                          }
                      },
                      {
                        "type": "object",
                        "required": [
                          "id",
                          "count"
                          ],
                          "unevaluatedProperties": false,
                          "properties": {
                            "ifdType": {
                              "type": "string",
                              "const": "org.iupac.fairdata.structure.IFDStructureCollection"
                            },
                            "ifdTypeExtends": {
                              "type": "string",
                              "const": "org.iupac.fairdata.core.IFDCollection"
                            },
                            "id": {
                              "type": "string",
                              "const": "structures"
                            },
                            "count": {
                              "type": "integer"
                            }
                          }
                      },
                      {
                        "type": "object",
                        "required": [
                          "id",
                          "count"
                          ],
                          "unevaluatedProperties": false,
                          "properties": {
                            "ifdType": {
                              "type": "string",
                              "const": "org.iupac.fairdata.dataobject.IFDDataObjectCollection"
                            },
                            "ifdTypeExtends": {
                              "type": "string",                              
                              "const": "org.iupac.fairdata.core.IFDCollection"
                            },
                            "id": {
                              "type": "string",
                              "const": "spectra"
                            },
                            "count": {
                              "type": "integer"
                            }
                          }
                      },
                      {
                        "type": "object",
                        "required": [
                          "id",
                          "count"
                          ],
                          "unevaluatedProperties": false,
                          "properties": {
                            "id": {
                              "type": "string",
                              "const": "compounds"
                            },
                            "ifdType": {
                              "type": "string",
                              "const": "org.iupac.fairdata.contrib.fairspec.FAIRSpecCompoundCollection"
                            },
                            "ifdTypeExtends": {
                              "type": "string",
                              "const": "org.iupac.fairdata.derived.IFDStructureDataAssociationCollection;org.iupac.fairdata.core.IFDAssociationCollection"
                            },
                            "count": {
                              "type": "integer"
                            }
                          }
                      },
                      {
                        "type": "object",
                        "required": [
                          "id",
                          "count"
                          ],
                          "unevaluatedProperties": false,
                          "properties": {
                            "ifdType": {
                              "type": "string",
                              "const": "org.iupac.fairdata.contrib.fairspec.FAIRSpecAnalysisCollection"
                            },
                            "ifdTypeExtends": {
                              "type": "string",
                              "const": "org.iupac.fairdata.derived.IFDStructureAnalysisAssociationCollection;org.iupac.fairdata.core.IFDAssociationCollection"
                            },            
                            "id": {
                              "type": "string",
                              "const": "analyses"
                            },
                            "count": {
                              "type": "integer"
                            }
                          }
                      }
                      ]
                  }
                },
                "relatedCount": {
                  "description": "count of items related to this finding aid",
                  "type": "integer"
                },
                "resourceCount": {
                  "description": "count of resources referenced in this finding aid",
                  "type": "integer"
                }
              }
            },
            "relatedItems": {
              "type": "array",
              "items": {
                "type": "object",
                "unevaluatedProperties": false,
                "properties": {
                  "type": {
                    "description": "typically 'publication' or 'dataset'",
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "authors": {
                    "type": "string"
                  },
                  "doi": {
                    "type": "string",
                    "description": "A full DOI reference to this digital object, including the protocal and host; generally to an HTML landing page describing this object"
                  },
                  "doiLink": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
                  "metadata": {
                    "description": "The actual metadata record from CrossRef or DataCite (typically)",
                    "type": "object"
                  },
                  "metadataSource": {
                    "type": "object",
                    "unevaluatedProperties": false,
                    "properties": {
                      "registrationAgency": {
                        "type": "string"
                      },
                      "metadataUrl": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            },
            "resources": {
              "type": "object",
              "unevaluatedProperties": false,
              "patternProperties": {
                "^\\S+([ ]\\S+)*": {
                  "type": "object",
                  "required": [
                    "ref"
                    ],
                    "unevaluatedProperties": false,
                    "properties": {
                      "ifdType": {
                        "type": "string",
                        "const": "org.iupac.fairdata.core.IFDResource"
                      },
                      "ref": {
                        "type": "string"
                      },
                      "len": {
                        "type": "number"
                      }
                    }
                }
              }
            },
            "collectionSet": {
              "unevaluatedProperties": false,
              "$ref": "#/$defs/def_collectionSet"
            }
          }
      }
    },
    "$defs": {
      "def_field_id": {
        "description": "an optional unique identifier, for example, a compound number such as 38b or a DOI such as 10.14469/hpc/14635 must not start nor end in a space character",
        "type": "string",
        "pattern": "^\\S+([ ]\\S+)*"
      },      
      "def_collectionSet" : {
        "type": "object",
        "required": [
          "itemsByID"
          ],
          "properties": {
              "note": {
                  "description": "a processing note created by the creator of the finding aid",
                  "type": "string"
                },
                "label": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "doi": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
            "ifdType": {
              "type": "string",
              "const": "org.iupac.fairdata.core.IFDCollectionSet"
            },
            "ifdTypeExtends": {
              "type": "string",
              "const": "org.iupac.fairdata.core.IFDCollection"
            },
            "resourceID": {
              "type": "string"
            },
            "propertyPrefix": {
              "type": "string"
            },
            "ifdProperties": {
              "type": "object",
              "description": "Each entry is a name of a defined property, starting with 'IFD.property.' and continuing with a dot-seperated set of qualifiers that consist only of lower-case or digit a-z0-9 characters. Only the part of this name following the 'propertyPrefix' value is given here.",
              "unevaluatedProperties": false,
              "properties": {
                
"source_data_doi":{"type" : "string"},
"source_data_dois":{"type" : "string"},
"source_data_license_name":{"type" : "string"},
"source_data_license_uri":{"type" : "string"},
"source_data_uri":{"type" : "string"},
"source_data_uris":{"type" : "string"},
"source_publication_doi":{"type" : "string"},
"source_publication_uri":{"type" : "string"},
"source_repository_doi":{"type" : "string"},
"source_repository_uri":{"type" : "string"}

              }
            },
            "attributes": {             
                "unevaluatedProperties": false,
                "$ref": "#/$defs/def_attributes"                          
              },
            "itemsByID": {
              "type": "object",
              "properties": {                      
                "samples": {
                  "unevaluatedProperties": false,
                  "$ref": "#/$defs/def_samples"
                },
                "structures": {
                  "unevaluatedProperties": false,
                  "$ref": "#/$defs/def_structures"
                },
                "spectra": {
                  "unevaluatedProperties": false,
                  "$ref": "#/$defs/def_spectra"
                },
                "compounds": {
                  "unevaluatedProperties": false,
                  "$ref": "#/$defs/def_compounds"
                },
                "analyses": {
                  "unevaluatedProperties": false,
                  "$ref": "#/$defs/def_analyses"
                }
              }
            }
          }
      },
      "def_structures": {
        "type": "object",
        "required": [
          "itemsByID"
          ],
          "properties": {
              "note": {
                  "description": "a processing note created by the creator of the finding aid",
                  "type": "string"
                },
                "label": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "doi": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
            "ifdType": {
              "type": "string",
              "const": "org.iupac.fairdata.structure.IFDStructureCollection"
            },
            "ifdTypeExtends": {
              "type": "string",
              "const": "org.iupac.fairdata.core.IFDCollection"
            },
            "itemType": {
              "type": "string",
              "const": "org.iupac.fairdata.structure.IFDStructure"
            },
            "itemTypeExtends": {
              "type": "string",
              "const": "org.iupac.fairdata.core.IFDRepresentableObject"
            },
            "itemsByID": {
              "type": "object",   
              "unevaluatedProperties": false,
              "patternProperties": {
                "^\\S+([ ]\\S+)*" : {
                  "unevaluatedProperties": false,
                  "$ref": "#/$defs/def_structure"
                }
              }
            }
          }
      },
      "def_structure": {
        "type":"object",
        "required": [
          "representations"
          ],
          "properties": {
              "note": {
                  "description": "a processing note created by the creator of the finding aid",
                  "type": "string"
                },
                "label": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "doi": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
            "ifdType": {
              "type": "string",
              "const": "org.iupac.fairdata.structure.IFDStructure"
            },
            "ifdTypeExtends": {
              "type": "string",
              "const": "org.iupac.fairdata.core.IFDRepresentableObject"
            },
            "propertyPrefix": {
              "description": "The prefix to add to all IFDProperty keys in this block",
              "const": "IFD.property.structure"
            },
            "ifdProperties": {
              "type": "object",
              "description": "Each entry is a name of a defined property, starting with 'IFD.property.' and continuing with a dot-seperated set of qualifiers that consist only of lower-case or digit a-z0-9 characters. Only the part of this name following the 'propertyPrefix' value is given here.",
              "unevaluatedProperties": false,
              "properties": {
                
"cell_formula":{"type" : "string"},
"empirical_formula":{"type" : "string"},
"inchikey":{"type" : "string"},
"molecular_formula":{"type" : "string"}

              }
            },
            "attributes": {             
              "unevaluatedProperties": false,
              "$ref": "#/$defs/def_attributes"                          
            },
            "representations": {
              "type": "array",
              "items" : {
                "unevaluatedProperties": false,
                "$ref": "#/$defs/def_representation"                          
              }
            }
          }
      },      
      "def_spectra" : {
        "type": "object",
        "required": [
          "itemsByID"
          ],
          "properties": {
              "note": {
                  "description": "a processing note created by the creator of the finding aid",
                  "type": "string"
                },
                "label": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "doi": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
            "ifdType": {
              "type": "string",
              "const": "org.iupac.fairdata.dataobject.IFDDataObjectCollection"
            },
            "ifdTypeExtends": {
              "type": "string",
              "const": "org.iupac.fairdata.core.IFDCollection"
            },
            "itemType": {
              "type": "string"
            },
            "itemTypeExtends": {
              "type": "string"
            },
            "itemsByID": {
              "type": "object",   
              "unevaluatedProperties": false,
              "patternProperties": {
                "^\\S+([ ]\\S+)*" : {
                  "unevaluatedProperties": false,
                  "$ref": "#/$defs/def_spectrum"                          
                }
              }
            }
          }
      },
      "def_spectrum" : {
        "type": "object",
        "required": [
            "representations"
            ],
        "properties": {
          "note": {
            "description": "a processing note created by the creator of the finding aid",
            "type": "string"
          },
          "label": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "doi": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
          "expt_timestamp": {
            "description": "date and time of creation ISO 8601 date+time (UTC), for example: 2025-04-17T18:55Z",
            "type": "integer"
          },
          "expt_originating_sample_id": {
            "type": "string"
          },
          "expt_title": {
            "type": "string"
          },
          "instr_manufacturer_name": {
            "type": "string"
          },
          "propertyPrefix": {
            "description": "The prefix to add to all IFDProperty keys in this block",
            "type": "string",
            "const": "IFD.property.dataobject.fairspec"
          },
          "ifdProperties": {
            "type": "object",
            "description": "Each entry is a name of a defined property, starting with 'IFD.property.' and continuing with a dot-seperated set of qualifiers that consist only of lower-case or digit a-z0-9 characters. Only the part of this name following the 'propertyPrefix' value is given here.",
            "unevaluatedProperties": false,
            "properties": {
              
"expt_originating_sample_id":{"type" : "string"},
"nmr.expt_date_time_acquired":{"type" : "string"},
"nmr.expt_date_time_processed":{"type" : "string"},
"nmr.expt_description":{"type" : "string"},
"nmr.expt_dimension":{"type" : "string"},
"nmr.expt_id":{"type" : "string"},
"nmr.expt_nucl1":{"type" : "string"},
"nmr.expt_nucl2":{"type" : "string"},
"nmr.expt_nucl3":{"type" : "string"},
"nmr.expt_offset_freq1":{"type":"number"},
"nmr.expt_offset_freq2":{"type":"number"},
"nmr.expt_offset_freq3":{"type":"number"},
"nmr.expt_pulse_program":{"type" : "string"},
"nmr.expt_solvent":{"type" : "string"},
"nmr.expt_solvent_common_name":{"type" : "string"},
"nmr.expt_solvent_InChI":{"type" : "string"},
"nmr.expt_solvent_InChIKey":{"type" : "string"},
"nmr.expt_thermodynamic_temperature":{"type":"number"},
"nmr.instr_nominal_freq":{"type":"number"},
"nmr.instr_probe_type":{"type" : "string"},
"nmr.instr_proton_freq":{"type":"number"}

            }
          },
          "attributes": {             
            "unevaluatedProperties": false,
            "$ref": "#/$defs/def_attributes"                          
          },
          "exptMethod": {
            "type": "string"
          },
          "representations": {
            "type": "array",
            "items" : {
              "unevaluatedProperties": false,
              "$ref": "#/$defs/def_representation"                          
            }
          }
        }
      },
      "def_compounds" : {
        "type": "object",
        "required": [
          "itemsByID"
          ],
          "properties": {
              "note": {
                  "description": "a processing note created by the creator of the finding aid",
                  "type": "string"
                },
                "label": {
                    "type": "string"
                  },
                  "description": {
                    "type": "string"
                  },
                  "doi": {
                    "type": "string"
                  },
                  "url": {
                    "type": "string"
                  },
            "ifdType": {
              "type": "string",
              "const": "org.iupac.fairdata.contrib.fairspec.FAIRSpecCompoundCollection"
            },
            "ifdTypeExtends": {
              "type": "string",
              "const": "org.iupac.fairdata.derived.IFDStructureDataAssociationCollection;org.iupac.fairdata.core.IFDAssociationCollection"
            },                
            "itemType": {
              "type": "string",
              "const": "org.iupac.fairdata.contrib.fairspec.FAIRSpecCompoundAssociation"
            },
            "itemTypeExtends": {
              "type": "string",
              "const": "org.iupac.fairdata.derived.IFDStructureDataAssociation;org.iupac.fairdata.core.IFDAssociation"
            },                
            "itemsByID": {
              "unevaluatedProperties": false,
              "$ref": "#/$defs/def_compound"                       
            }
          }
      },
      "def_compound" : {
        "type": "object",
        "patternProperties": {
          "^\\S+([ ]\\S+)*" : {
            "type": "object",
            "unevaluatedProperties": false,
            "properties": {
                "note": {
                    "description": "a processing note created by the creator of the finding aid",
                    "type": "string"
                  },
                  "label": {
                      "type": "string"
                    },
                    "description": {
                      "type": "string"
                    },
                    "doi": {
                      "type": "string"
                    },
                    "url": {
                      "type": "string"
                    },
              "ifdProperties": {
                "type": "object",
                "description": "Each entry is a name of a defined property, starting with 'IFD.property.' and continuing with a dot-seperated set of qualifiers that consist only of lower-case or digit a-z0-9 characters. Only the part of this name following the 'propertyPrefix' value is given here.",
                "unevaluatedProperties": false,
                "properties": {
                  
"chirality":{"type" : "string"}

                }
              },
              "attributes": {             
                "unevaluatedProperties": false,
                "$ref": "#/$defs/def_attributes"                          
              },
              "itemsByID": {
                "type": "object",
                "unevaluatedProperties": false,
                "properties": {
                  "structures" :{
                    "type": "array",
                    "items": {
                      "$ref": "#/$defs/def_field_id"
                    }
                  },
                  "spectra" :{
                    "type": "array",
                    "items": {
                      "$ref": "#/$defs/def_field_id"
                    }
                  }
                }
              }
            }
          }
        }
      },
      "def_attributes" : {
        "type": "object",
        "description": "an optional set of key/value pairs that are not part of the IUPAC FAIRData standard or its extension. Characters of the keys must be one of[A-Za-z0-9_] or the space character and must be trimmed of any space character",
        "patternProperties": {
          "^\\S+([ ]\\S+)*": {
            "type": [
              "string",
              "number",
              "array"
              ]
          }
        }
      },
      "def_representation" : {
        "type": "object",
        "properties": {
          "ifdType" : {
            "type": "string"
          },
          "ifdTypeExtends" : {
            "type": "string"
          },
          "representationType": {
            "type": "string"
          },
          "mediaType": {
            "type": "string"
          },
          "len": {
            "type": "integer"
          },
          "note": {
            "type": "string"
          },
          "data": {
            "description": "a string of data such as a SMILES, or a BASE-64-encoded string starting with ';base64,'",
            "type": "string"
          },
          "ref": {
            "type": "object",
            "unevaluatedProperties": false,
            "properties": {
              "ifdType" : {
                "const" : "org.iupac.fairdata.core.IFDReference"
              },
              "ifdTypeExtends" : {
                "const" : ""
              },
              "resourceID": {
                "type": "string"
              },
              "originPath": {
                "type": "string"
              },
              "localPath": {
                "type": "string"
              },
              "localName": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "doi": {
                "type": "string"
              }
            }
          }
        }
      },
      "def_samples": {
      },
      "def_analyses": {
      }
    }

}